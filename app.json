{
  "expo": {
    "name": "TickTask",
    "slug": "ticktask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.ticktask.ticktask",
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "config": {
        "googleMapsApiKey": "AIzaSyCj8Fq-ndpG4FEyv4JVq4DEvccn9ReEleM"
      }
    },
    "android": {
      "package": "com.ticktask.ticktask",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCs_PU_ywyWxFGDLAo0BfR4W7sFjjKr9UQ"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "expo-localization", "expo-sqlite", "expo-font", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6e45986b-68f2-48d4-9825-700a0ca0429d"
      }
    },
    "owner": "helinnokcu"
  }
}
